{
  "name": "madside",
  "private": true,
  "version": "0.27.5",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "pnpm --filter @madside/ide dev",
    "build": "pnpm --filter @madside/ide build",
    "lint": "eslint . --max-warnings 0",
    "preview": "pnpm --filter @madside/ide preview",
    "test": "pnpm --filter @madside/ide test",
    "graph": "madge --extensions ts,tsx --image wiki/architecture/dep-graph.svg apps/ide/src packages",
    "graph:circular": "madge --circular --extensions ts,tsx apps/ide/src packages",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "madge": "^8.0.0",
    "markdownlint-cli": "^0.48.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
