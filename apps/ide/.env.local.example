# GitHub persistence — LOCAL dev config (#158).
#
# Copy to `.env.local` (gitignored by `*.local`) to light up the GitHub layer in
# `pnpm dev`. Both values are PUBLIC (no secrets — the gh-auth broker holds the
# App's client_secret). Leave `.env.local` absent => madside runs browser-only.
#
#   cp apps/ide/.env.local.example apps/ide/.env.local   # then fill in
#
# Vite loads `.env.local` from apps/ide/ automatically; restart `pnpm dev` after edits.

# gh-auth broker base URL. Either the deployed Worker, or run it locally:
#   cd ~/src/gh_broker && just dev      # wrangler dev on http://localhost:8787
VITE_GH_BROKER_URL=http://localhost:8787

# GitHub App public client_id (e.g. Iv1.xxxx).
VITE_GH_CLIENT_ID=

# One-time setup so the OAuth round-trip works against localhost:
#   1. GitHub App: add callback URL  http://localhost:5173/   (dev server runs at
#      :5173; redirectUri = location.origin + "/" — site root, NOT /auth/callback).
#   2. gh_broker `.env` APPS: add "http://localhost:5173" to that App's `origins`,
#      then `just deploy` (or `just dev` reads .env locally).
#   3. Install the GitHub App on your dedicated test repo (Contents: read+write).
