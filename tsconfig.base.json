{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode + project-references emission. Composite projects need
       emit enabled (TS6310). emitDeclarationOnly + outDir keeps JS out of
       the repo while letting tsc -b cache type info per layer. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./node_modules/.tmp/dts",
    "jsx": "react-jsx",

    /* Layer aliases (ADR-0002) — shared across every layer config */
    "paths": {
      "@core":       ["./packages/core/src"],
      "@core/*":     ["./packages/core/src/*"],
      "@ports":      ["./packages/ports/src"],
      "@ports/*":    ["./packages/ports/src/*"],
      "@adapters":   ["./apps/ide/src/adapters"],
      "@adapters/*": ["./apps/ide/src/adapters/*"],
      "@app":        ["./apps/ide/src/app"],
      "@app/*":      ["./apps/ide/src/app/*"],
      "@ui":         ["./apps/ide/src/ui"],
      "@ui/*":       ["./apps/ide/src/ui/*"]
    },

    /* Linting */
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  }
}
