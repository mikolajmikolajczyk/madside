{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.plugins.tsbuildinfo"
  },
  "include": [
    "packages/toolchain-mads/src/**/*",
    "packages/toolchain-ca65/src/**/*",
    "packages/toolchain-z88dk/src/**/*",
    "packages/machine-atari-xl/src/**/*",
    "packages/machine-c64/src/**/*",
    "packages/machine-nes/src/**/*",
    "packages/machine-zx/src/**/*",
    "packages/emulator-c64-chips/src/**/*",
    "packages/emulator-nes-jsnes/src/**/*",
    "packages/emulator-zx-chips/src/**/*",
    "packages/debug-atari-6502/src/**/*",
    "packages/debug-zx-z80/src/**/*",
    "packages/panel-memory/src/**/*",
    "packages/panel-output/src/**/*",
    "packages/panel-ppu/src/**/*",
    "packages/panel-registers/src/**/*",
    "packages/converters/src/**/*",
    "packages/editors/src/**/*"
  ],
  "references": [
    { "path": "./tsconfig.core.json" },
    { "path": "./tsconfig.ports.json" },
    // TODO(M3): drop adapters once recipeEngine + registry stop importing
    // @adapters directly. ESLint boundaries already flags the violation;
    // the project reference is the transitional concession.
    { "path": "./tsconfig.adapters.json" }
  ]
}
